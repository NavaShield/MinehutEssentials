{
  "schemaVersion": 1,
  "id": "minehutessentials",
  "version": "${version}",
  "name": "MinehutEssentials",
  "description": "An essential mod to block all the minehut annoyances",
  "authors": [],
  "contact": {
    "homepage": "https://github.com/NavaShield/MinehutEssentials/",
    "issues": "https://github.com/NavaShield/MinehutEssentials/issues"
  },
  "license": "All-Rights-Reserved",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "github.navashield.client.minehutessentialsDataGenerator"
    ],
    "client": [
      "github.navashield.client.minehutessentialsClient"
    ],
    "modmenu": [
      "github.navashield.client.MinehutEssentialsModMenuIntegration"
    ]
  },
  "mixins": [
    "minehutessentials.mixins.json",
    {
      "config": "minehutessentials.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
